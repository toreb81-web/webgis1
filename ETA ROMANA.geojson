{ "type": "Feature", "properties": { "Toponimo": "Vezza", "Comune": "Capolona", "Provincia": "AR", "Definizion": "Rinvenimento sporadico", "Descrizion": "Nel tratto tra le due località di\nPalazzo e di Serboli durante lavori\nagricoli è stato recuperata un a impugnatura\ndi coltello di osso intagliato\nterminante a testa femminile,\nforse di età imperiale", "Rif Cron": "romano", "Data iniz": 0, "Data fine": 0, "Individuaz": "Rinvenimento fortuito", "Biblio": "ASAT, pag. 228, n. 32", "Posizionam": "Approssimato", "Affidab": "Buona", "ID": "CA16", "TAVOLA": "1B" }, "geometry": { "type": "MultiPoint", "coordinates": [ [ 11.806229332783781, 43.568263310180612 ] ] } },
{ "type": "Feature", "properties": { "Toponimo": "Migliarino", "Comune": "Capolona", "Provincia": "AR", "Definizion": "Tomba", "Descrizion": "Rinvenuta nel 1860, in proprietà di\nPaolo Tarsettí, un a urnetta cineraria\ndi marmo con coperchio a doppio\nspiovente e iscrizione (CIL XI,\n1894) datata tra il I sec. a.C. e il I\nsec. d.C., ora ad Arezzo", "Rif Cron": "Età Romano Repubblicana / Età Romana", "Data iniz": -100, "Data fine": 100, "Individuaz": "Rinvenimento fortuito", "Biblio": "Torelli 1992, n. 29, p. 228", "Posizionam": "Approssimato", "Affidab": "Buona", "ID": "CA10", "TAVOLA": "1A" }, "geometry": { "type": "MultiPoint", "coordinates": [ [ 11.825717952881572, 43.584907558416276 ] ] } },
{ "type": "Feature", "properties": { "Toponimo": "Fontinberna", "Comune": "Capolona", "Provincia": "AR", "Definizion": "Cisterna", "Descrizion": "Presso Case Fani durante lavori di\nristrutturazione delle condutture di\nuna sorgente, è stata rinvenuta una\ncisterna di epoca romano-imperiale\nrivestita di cocciopesto", "Rif Cron": "romano", "Data iniz": 0, "Data fine": 0, "Individuaz": "Rinvenimento fortuito", "Biblio": "ASAT,p. 228, n. 33", "Posizionam": "Approssimato", "Affidab": "Buona", "ID": "CA14", "TAVOLA": "1A" }, "geometry": { "type": "MultiPoint", "coordinates": [ [ 11.822344442693383, 43.580519990076425 ] ] } },
{ "type": "Feature", "properties": { "Toponimo": "S. Maria in Carda", "Comune": "Talla", "Provincia": "AR", "Definizion": "Strutture", "Descrizion": "muratura a secco con pietre in arenaria locale di 30x25 m., di spessore di 60-70 cm. È stata raccolta ceramica acroma apparentemente di tipo romano. Non sono presenti laterizi, per cui si presume che la copertura fosse in materiale stramineo", "Rif Cron": "romano", "Data iniz": -50, "Data fine": 200, "Individuaz": "Ricognizione", "Biblio": "Ricognizioni GAC 1997-2000 (TA032)", "Posizionam": "Esatto", "Affidab": "Buona", "ID": "TA1", "TAVOLA": "5A" }, "geometry": { "type": "MultiPoint", "coordinates": [ [ 11.759036715338448, 43.641026341829438 ] ] } },
{ "type": "Feature", "properties": { "Toponimo": "Casa Brandano", "Comune": "Talla", "Provincia": "AR", "Definizion": "Area di frammenti fittili", "Descrizion": "nei pressi dei ruderi di Casa Brandano sono stati raccolti frammenti di tegoli e ceramica figulina romana.", "Rif Cron": "romano", "Data iniz": -100, "Data fine": 300, "Individuaz": "Ricognizione", "Biblio": "Ricognizioni GAC 2010 (TA023)", "Posizionam": "Esatto", "Affidab": "Buona", "ID": "TA3", "TAVOLA": "5A" }, "geometry": { "type": "MultiPoint", "coordinates": [ [ 11.783871410089576, 43.609684831520035 ] ] } },
{ "type": "Feature", "properties": { "Toponimo": "La Quota", "Comune": "Talla", "Provincia": "AR", "Definizion": "Area di frammenti fittili", "Descrizion": "Nell'area sono visibili alcune concentrazioni di laterizi e ceramica comune romana", "Rif Cron": "romano", "Data iniz": 1, "Data fine": 300, "Individuaz": "Ricognizione", "Biblio": "Ricognizioni GAC 2000 (TA025)", "Posizionam": "Esatto", "Affidab": "Buona", "ID": "TA5", "TAVOLA": "5A" }, "geometry": { "type": "MultiPoint", "coordinates": [ [ 11.806749875725933, 43.603319241058344 ] ] } },
