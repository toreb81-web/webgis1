{ "type": "Feature", "properties": { "Toponimo": "S. Lorenzo", "Comune": "Talla", "Provincia": "AR", "Definizion": "Area di frammenti fittili", "Descrizion": "Nei pressi dell’abitato di S.Lorenzo , nei campi che costeggiano la strada per Bicciano, sono evidenti cumuli di pietre con frammenti di laterizi apparentemente romani e ceramica acroma", "Rif Cron": "romano", "Data iniz": -100, "Data fine": 200, "Individuaz": "Ricognizione", "Biblio": "Ricognizioni GAC 1996 (TA013); G.A.C. 1999, Tav.XVIII, p.88", "Posizionam": "Esatto", "Affidab": "Buona", "ID": "TA6", "TAVOLA": "5B" }, "geometry": { "type": "MultiPoint", "coordinates": [ [ 11.795577401423397, 43.57627201979502 ] ] } },
{ "type": "Feature", "properties": { "Toponimo": "La Volta", "Comune": "Talla", "Provincia": "AR", "Definizion": "Area di frammenti fittili", "Descrizion": "In prossimità dei campi sotto il podere la Volta fu trovato in due occasioni un frammento di sigillata, una fuseruola e un manico di boccale", "Rif Cron": "romano", "Data iniz": -50, "Data fine": 100, "Individuaz": "Ricognizione", "Biblio": "Ricognizioni GAC 1983-1985 (TA012)", "Posizionam": "Esatto", "Affidab": "Buona", "ID": "TA7", "TAVOLA": "5B" }, "geometry": { "type": "MultiPoint", "coordinates": [ [ 11.77555482107223, 43.570351026859406 ] ] } },
